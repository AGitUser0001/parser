{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "lib": [
      "ES2022"
    ],
    "types": [],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "strict": true,
    "outDir": "./dist/",
    "rootDir": "./src/",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "./src/**.ts"
  ]
}
