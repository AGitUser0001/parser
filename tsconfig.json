{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "lib": [
      "ES2022"
    ],
    "types": [],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "strict": true,
    "outDir": "./dist/",
    "rootDir": "./",
    "declaration": true,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "*.ts",
    "dsl/*.ts",
    "node_modules/js-tokens/index.js"
  ]
}
