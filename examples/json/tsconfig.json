{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "skipLibCheck": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "strict": true,
    "outDir": "./",
    "declaration": true,
    "sourceMap": true,
    "composite": true
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "./**/*.js",
    "./**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../"
    }
  ]
}
