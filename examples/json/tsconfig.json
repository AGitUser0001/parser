{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "outDir": "./",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "./**.ts"
  ],
  "exclude": [
    "./**.js",
    "./**.d.ts"
  ]
}
