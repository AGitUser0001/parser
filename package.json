{
  "name": "parser",
  "version": "1.0.0",
  "description": "A parser library based on a grammar defined using nested arrays.",
  "license": "BSD-3-Clause",
  "author": "AGitUser0001",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module-sync": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dsl/dsl": null,
    "./shared": null,
    "./*": {
      "types": "./dist/*.d.ts",
      "module-sync": "./dist/*.js",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./dsl": {
      "types": "./dist/dsl/dsl.d.ts",
      "module-sync": "./dist/dsl/dsl.js",
      "import": "./dist/dsl/dsl.js",
      "default": "./dist/dsl/dsl.js"
    }
  },
  "scripts": {
    "build": "tsgo --build",
    "build-all": "npm run build && npm run build --ws && npm --prefix examples/json run build",
    "repl": "tsx --import ./examples/repl-preload.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AGitUser0001/parser"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "tsx": "^4.21.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "js-tokens": "^10.0.0"
  },
  "workspaces": [
    "ui"
  ]
}
